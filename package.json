{
  "name": "flowhelm",
  "version": "0.1.1",
  "description": "Secure, multi-tenant AI agent orchestrator",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "flowhelm": "dist/cli.js"
  },
  "files": [
    "dist/",
    "container-image/",
    "scripts/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp src/orchestrator/schema.sql dist/orchestrator/schema.sql",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "cron-parser": "^5.5.0",
    "grammy": "^1.42.0",
    "node-forge": "^1.4.0",
    "postgres": "^3.4.8",
    "yaml": "^2.7.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-forge": "^1.3.14",
    "eslint": "^9.35.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22"
  }
}
